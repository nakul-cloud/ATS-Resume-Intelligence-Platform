# APP SETTINGS
APP_NAME="ATS Resume Intelligence"
ENV=development
PORT=3000

# DATABASE SETTINGS
DATABASE_URL="postgresql+asyncpg://postgres:postgres123@localhost:5432/atsdb"

# SECURITY SETTINGS
# Generate a real secret using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="generate_using_python_secrets_token_hex_32"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_IN_MINUTES=60

# AI SETTINGS
QDRANT_URL="http://localhost:6333"
QDRANT_VECTOR_SIZE=1024

GROQ_API_KEY=
EMBEDDING_MODEL_NAME="BAAI/bge-large-en-v1.5"
GROQ_CHAT_MODEL="llama-3.3-70b-versatile"
SIMILARITY_THRESHOLD=0.5
TOP_K_CHUNKS=3

# REDIS SETTINGS
REDIS_HOST="localhost"
REDIS_PORT=6379

# LLM FALLBACK & ENDPOINT SETTINGS (e.g. for custom proxies/OpenRouter/unified gateways)
LLM_FALLBACK_MODELS="openai/gpt-oss-120b,qwen/qwen3.6-27b,llama-3.3-70b-versatile"
# LLM_BASE_URL="https://api.groq.com/openai/v1"

# MAIL SETTINGS (Mailtrap SMTP Sandbox)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=    
MAIL_PASSWORD=
MAIL_FROM_EMAIL=noreply@resumeintelligence.com


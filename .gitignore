# Production-ready .gitignore for Resume Intelligence project
# ----------------------------------------------------------
# Python files & caches
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pdb
*.egg
*.egg-info/
.dist/
build/
*.manifest
*.spec

# Virtual environments & environment variables
venv/
.env
.env.*
.venv/
ENV/
env/
.Python

# IDE & editor settings
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Operating system files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Windows shortcuts
*.lnk

# Node / Frontend artifacts (Vite, npm, yarn, pnpm)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/
.cache/
.next/
out/
/dist/

# Build output directories
static/
public/

# Security / secret keys
*.key
*.pem
*.crt

# Git auxiliary files
*.orig
*.rej

# Test & coverage reports
coverage/
.coverage
htmlcov/
*.cover
*.coverage.*
.cache
nosetests.xml
coverage.xml
*.coveragerc
.pytest_cache/
html_report/
pytestdebug.log

# Miscellaneous logs
*.log

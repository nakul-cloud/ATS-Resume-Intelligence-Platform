# Production-ready .gitignore for Resume Intelligence project
# ----------------------------------------------------------

# Python files & caches
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pdb
*.egg
*.egg-info/
.dist/
build/
*.manifest
*.spec

# Virtual environments & environment variables
venv/
.venv/
ENV/
env/
.Python

# Environment variables — keep example, ignore secrets
.env
.env.*
!.env.example

# IDE & editor settings
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Operating system files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Windows shortcuts
*.lnk

# Node / Frontend artifacts (Vite, npm, yarn, pnpm)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/
.cache/
.next/
out/
/dist/

# Build output directories (project-specific — do not ignore intentional static/)
# static/
# public/

# Security / secret keys
*.key
*.pem
*.crt

# Git auxiliary files
*.orig
*.rej

# Test & coverage reports
coverage/
.coverage
htmlcov/
*.cover
*.coverage.*
nosetests.xml
coverage.xml
*.coveragerc
.pytest_cache/
html_report/
pytestdebug.log

# Application logs (Loguru output)
*.log
application.json
logs/

# Temporary uploaded resume files (ARQ worker processes these — never commit)
temp/

# Qdrant local storage (used only in development without Docker)
qdrant_storage/

# Alembic migration __pycache__ (auto-generated)
app/migrations/__pycache__/

# SonarQube analysis cache and auth token config
.sonar/
.scannerwork/
sonar-project.properties

# Graphify knowledge graph output (auto-generated, large)
graphify-out/

# uv lock file changes (commit uv.lock if you pin deps, otherwise ignore)
# uv.lock

# ARQ worker task artifacts
arq_job_results/


# Sonar Cloud
reports/
scripts/sonar_report.py

# Local planning, CSV audit reports, and data dumps
Implementation_plan/
sonar_issues_report.csv
*.csv
candidate_skills.json
candidates_parsed.json
resumes_raw.json
